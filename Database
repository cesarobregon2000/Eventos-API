CREATE OR ALTER PROCEDURE [dbo].[PR_CREAR_RESERVA]
@EVENTO_ID INT, @NOMBRE VARCHAR (150), @EMAIL VARCHAR (200), @CANTIDAD INT
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRY
        BEGIN TRANSACTION;
        DECLARE @CLIENTE_ID AS INT;
        DECLARE @CAPACIDAD AS INT;
        DECLARE @VENDIDAS AS INT;
        DECLARE @FECHA_INICIO AS DATETIME;
        DECLARE @PRECIO AS DECIMAL (12, 2);
        BEGIN TRANSACTION;
        SELECT @CLIENTE_ID = CLIENTE_ID
        FROM   CLIENTE WITH (UPDLOCK)
        WHERE  EMAIL = @EMAIL;
        IF @CLIENTE_ID IS NULL
            BEGIN
                INSERT  INTO CLIENTE (NOMBRE, EMAIL)
                VALUES              (@NOMBRE, @EMAIL);
                SET @CLIENTE_ID = SCOPE_IDENTITY();
            END
        ELSE
            BEGIN
                UPDATE CLIENTE
                SET    NOMBRE = @NOMBRE,
                       FECHA  = GETDATE()
                WHERE  CLIENTE_ID = @CLIENTE_ID;
            END
        SELECT @CAPACIDAD = CAPACIDAD_MAXIMA,
               @FECHA_INICIO = FECHA_INICIO,
               @PRECIO = PRECIO_ENTRADA
        FROM   EVENTO WITH (UPDLOCK, ROWLOCK)
        WHERE  EVENTO_ID = @EVENTO_ID;
        IF @CAPACIDAD IS NULL
            BEGIN
                ROLLBACK;
                RAISERROR ('El evento no existe', 16, 1);
                RETURN;
            END
        IF @CANTIDAD < 1
            BEGIN
                ROLLBACK;
                RAISERROR ('La cantidad debe ser mayor a cero', 16, 1);
                RETURN;
            END
        IF DATEDIFF(HOUR, GETDATE(), @FECHA_INICIO) < 24
           AND @CANTIDAD > 5
            BEGIN
                ROLLBACK;
                RAISERROR ('Máximo 5 entradas cuando faltan menos de 24 horas para el evento', 16, 1);
                RETURN;
            END
        SELECT @VENDIDAS = ISNULL(SUM(CANTIDAD), 0)
        FROM   RESERVA WITH (UPDLOCK)
        WHERE  EVENTO_ID = @EVENTO_ID
               AND ESTADO IN ('CONFIRMADA', 'PENDIENTE_PAGO');
        IF DATEDIFF(MINUTE, GETDATE(), @FECHA_INICIO) < 60
            BEGIN
                ROLLBACK;
                RAISERROR ('No se permiten reservas con menos de 1 hora de anticipacion', 16, 1);
                RETURN;
            END
        IF @PRECIO > 100
           AND @CANTIDAD > 10
            BEGIN
                ROLLBACK;
                RAISERROR ('Máximo 10 entradas por transaccion para eventos > 100', 16, 1);
                RETURN;
            END
        IF (@VENDIDAS + @CANTIDAD) > @CAPACIDAD
            BEGIN
                ROLLBACK;
                RAISERROR ('No hay suficientes cupos disponibles', 16, 1);
                RETURN;
            END
        INSERT  INTO RESERVA (EVENTO_ID, CLIENTE_ID, CANTIDAD, ESTADO)
        VALUES              (@EVENTO_ID, @CLIENTE_ID, @CANTIDAD, 'PENDIENTE_PAGO');
        COMMIT TRANSACTION;
        COMMIT TRANSACTION;
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0
            ROLLBACK;
        THROW;
    END CATCH
END





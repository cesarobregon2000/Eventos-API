----------------------Trigger--------------------------------
CREATE TRIGGER TRG_EVENTO_NO_SOLAPAMIENTO
ON EVENTO
AFTER INSERT, UPDATE
AS
BEGIN
    IF EXISTS (
        SELECT 1
        FROM EVENTO E
        INNER JOIN inserted I
            ON E.VENUE_ID = I.VENUE_ID
           AND E.EVENTO_ID <> I.EVENTO_ID
           AND (
                I.FECHA_INICIO < E.FECHA_FIN
                AND I.FECHA_FIN > E.FECHA_INICIO
           )
           AND E.ESTADO = 'ACTIVO'
    )
    BEGIN
        RAISERROR ('Conflicto de horario: el venue ya tiene un evento en ese rango.', 16, 1);
        ROLLBACK TRANSACTION;
        RETURN;
    END
END;

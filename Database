CREATE DATABASE Eventos;
Use Eventos;

--------------------Tablas------------------------------

CREATE TABLE TIPO_EVENTO (
    TIPOEVEN_ID INT IDENTITY(1,1) PRIMARY KEY,
    NOMBRE VARCHAR(30) NOT NULL UNIQUE,
   ESTADO VARCHAR(10) NOT NULL
CHECK (ESTADO IN ('ACTIVO','INACTIVO'))
);

CREATE TABLE CIUDAD (
    CIUDAD_ID INT IDENTITY(1,1) PRIMARY KEY,
    CIUDAD_NOMBRE VARCHAR(100) NOT NULL UNIQUE
);

CREATE TABLE VENUE (
    VENUE_ID INT IDENTITY(1,1) PRIMARY KEY,

    NOMBRE VARCHAR(100) NOT NULL,

    CAPACIDAD INT NOT NULL,

    CIUDAD_ID INT NOT NULL,

    ESTADO VARCHAR(10) NOT NULL
CHECK (ESTADO IN ('ACTIVO','INACTIVO')),

    CONSTRAINT CK_VENUE_CAPACIDAD
        CHECK (CAPACIDAD > 0),

    CONSTRAINT FK_VENUE_CIUDAD
        FOREIGN KEY (CIUDAD_ID)
        REFERENCES CIUDAD(CIUDAD_ID)
);

CREATE TABLE CLIENTE (
    CLIENTE_ID INT IDENTITY(1,1) PRIMARY KEY,
    NOMBRE VARCHAR(150) NOT NULL,
    EMAIL VARCHAR(200) NOT NULL UNIQUE,
    FECHA DATETIME NOT NULL
);


CREATE TABLE EVENTO (
    EVENTO_ID INT IDENTITY(1,1) PRIMARY KEY,

    TITULO VARCHAR(100) NOT NULL,
    DESCRIPCION VARCHAR(500) NOT NULL,

    VENUE_ID INT NOT NULL,
    TIPO_EVENTO_ID INT NOT NULL,

    CAPACIDAD_MAXIMA INT NOT NULL,

    FECHA_INICIO DATETIME NOT NULL,
    FECHA_FIN DATETIME NOT NULL,

    PRECIO_ENTRADA DECIMAL(12,2) NOT NULL,

   ESTADO VARCHAR(10) NOT NULL,

    CONSTRAINT FK_EVENTO_VENUE
        FOREIGN KEY (VENUE_ID)
        REFERENCES VENUE(VENUE_ID),

    CONSTRAINT FK_EVENTO_TIPO
        FOREIGN KEY (TIPO_EVENTO_ID)
        REFERENCES TIPO_EVENTO(TIPOEVEN_ID),

    CONSTRAINT CK_EVENTO_FECHAS
        CHECK (FECHA_FIN > FECHA_INICIO),

    CONSTRAINT CK_EVENTO_CAPACIDAD
        CHECK (CAPACIDAD_MAXIMA > 0),

    CONSTRAINT CK_EVENTO_PRECIO
        CHECK (PRECIO_ENTRADA > 0),

    CONSTRAINT CK_EVENTO_ESTADO
        CHECK (ESTADO IN ('ACTIVO','CANCELADO','COMPLETADO'))
);

CREATE TABLE RESERVA (
    RESERVA_ID INT IDENTITY(1,1) PRIMARY KEY,

    EVENTO_ID INT NOT NULL,
    CLIENTE_ID INT NOT NULL,

    CANTIDAD INT NOT NULL,

    ESTADO VARCHAR(20) NOT NULL DEFAULT 'PENDIENTE_PAGO',

    CODIGO_RESERVA VARCHAR(20) UNIQUE NULL,

    FECHA_RESERVA DATETIME DEFAULT SYSDATETIME(),
    FECHA_CONFIRMACION DATETIME NULL,
    FECHA_CANCELACION DATETIME NULL,

    CONSTRAINT FK_RESERVA_EVENTO
        FOREIGN KEY (EVENTO_ID)
        REFERENCES EVENTO(EVENTO_ID),

    CONSTRAINT FK_RESERVA_CLIENTE
        FOREIGN KEY (CLIENTE_ID)
        REFERENCES CLIENTE(CLIENTE_ID),

    CONSTRAINT CK_RESERVA_CANTIDAD
        CHECK (CANTIDAD > 0),

    CONSTRAINT CK_RESERVA_ESTADO
        CHECK (
            ESTADO IN (
                'PENDIENTE_PAGO',
                'CONFIRMADA',
                'CANCELADA',
                'PERDIDA'
            )
        )
);

CREATE TABLE PAGO (
    PAGO_ID INT IDENTITY(1,1) PRIMARY KEY,

    RESERVA_ID INT NOT NULL,

    VALOR DECIMAL(12,2) NOT NULL,

    FECHA_PAGO DATETIME DEFAULT GETDATE(),

    ESTADO VARCHAR(20) NOT NULL,

    REFERENCIA VARCHAR(100),

    CONSTRAINT FK_PAGO_RESERVA
        FOREIGN KEY (RESERVA_ID)
        REFERENCES RESERVA(RESERVA_ID),

    CONSTRAINT CK_PAGO_VALOR
        CHECK (VALOR > 0),

    CONSTRAINT CK_PAGO_ESTADO
        CHECK (ESTADO IN ('PENDIENTE','APROBADO','RECHAZADO'))
);


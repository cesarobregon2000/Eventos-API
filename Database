CREATE OR ALTER PROCEDURE [dbo].[PR_CREAR_EVENTO]
@TITULO VARCHAR (100), @DESCRIPCION VARCHAR (500), @VENUE_ID INT, @TIPO_EVENTO_ID INT, @CAPACIDAD_MAXIMA INT, @FECHA_INICIO DATETIME, @FECHA_FIN DATETIME, @PRECIO_ENTRADA DECIMAL (12, 2)
AS
BEGIN
    DECLARE @CAPACIDAD_VENUE AS INT;
    BEGIN TRANSACTION;
    IF @FECHA_FIN <= @FECHA_INICIO
        BEGIN
            ROLLBACK;
            RAISERROR ('La fecha fin debe ser mayor a la fecha inicio', 16, 1);
            RETURN;
        END
    SELECT @CAPACIDAD_VENUE = CAPACIDAD
    FROM   VENUE
    WHERE  VENUE_ID = @VENUE_ID;
    IF @CAPACIDAD_VENUE IS NULL
        BEGIN
            ROLLBACK;
            RAISERROR ('Venue no existe', 16, 1);
            RETURN;
        END
    IF @CAPACIDAD_MAXIMA > @CAPACIDAD_VENUE
        BEGIN
            ROLLBACK;
            RAISERROR ('Capacidad del evento excede la del venue', 16, 1);
            RETURN;
        END
    IF DATENAME(WEEKDAY, @FECHA_INICIO) IN ('Saturday', 'Sunday')
       AND CAST (@FECHA_INICIO AS TIME) > '22:00'
        BEGIN
            ROLLBACK;
            RAISERROR ('Eventos en fin de semana no pueden iniciar despues de las 22:00', 16, 1);
            RETURN;
        END
    INSERT  INTO EVENTO (TITULO, DESCRIPCION, VENUE_ID, TIPO_EVENTO_ID, CAPACIDAD_MAXIMA, FECHA_INICIO, FECHA_FIN, PRECIO_ENTRADA, ESTADO)
    VALUES             (@TITULO, @DESCRIPCION, @VENUE_ID, @TIPO_EVENTO_ID, @CAPACIDAD_MAXIMA, @FECHA_INICIO, @FECHA_FIN, @PRECIO_ENTRADA, 'ACTIVO');
    COMMIT TRANSACTION;
END




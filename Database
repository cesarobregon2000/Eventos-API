CREATE OR ALTER PROCEDURE [dbo].[PR_CANCELAR_RESERVA]
@RESERVA_ID INT
AS
BEGIN
    DECLARE @FECHA_INICIO AS DATETIME;
    DECLARE @HORAS AS INT;
    DECLARE @ESTADO AS VARCHAR (20);
    BEGIN TRANSACTION;
    SELECT @FECHA_INICIO = E.FECHA_INICIO,
           @ESTADO = R.ESTADO
    FROM   RESERVA AS R
           INNER JOIN
           EVENTO AS E
           ON E.EVENTO_ID = R.EVENTO_ID
    WHERE  R.RESERVA_ID = @RESERVA_ID;
    IF @ESTADO = 'CANCELADA'
        BEGIN
            ROLLBACK;
            RAISERROR ('Ya esta cancelada', 16, 1);
            RETURN;
        END
    SET @HORAS = DATEDIFF(HOUR, GETDATE(), @FECHA_INICIO);
    IF @HORAS < 48
        BEGIN
            UPDATE RESERVA
            SET    ESTADO            = 'PERDIDA',
                   FECHA_CANCELACION = GETDATE()
            WHERE  RESERVA_ID = @RESERVA_ID;
        END
    ELSE
        BEGIN
            UPDATE RESERVA
            SET    ESTADO            = 'CANCELADA',
                   FECHA_CANCELACION = GETDATE()
            WHERE  RESERVA_ID = @RESERVA_ID;
        END
    COMMIT TRANSACTION;
END




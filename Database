CREATE OR ALTER   FUNCTION [dbo].[FN_REPORTAR_OCUPACION]
( )
RETURNS TABLE 
AS
RETURN 
    (SELECT   E.TITULO AS Evento,
              E.CAPACIDAD_MAXIMA AS CapacidadTotal,
              ISNULL(SUM(CASE WHEN R.ESTADO = 'CONFIRMADA' THEN R.CANTIDAD ELSE 0 END), 0) AS EntradasVendidas,
              E.CAPACIDAD_MAXIMA - ISNULL(SUM(CASE WHEN R.ESTADO = 'CONFIRMADA' THEN R.CANTIDAD ELSE 0 END), 0) AS EntradasDisponibles,
              ROUND((CAST (ISNULL(SUM(CASE WHEN R.ESTADO = 'CONFIRMADA' THEN R.CANTIDAD ELSE 0 END), 0) AS DECIMAL (18, 2)) / NULLIF (E.CAPACIDAD_MAXIMA, 0)) * 100, 2) AS PorcentajeOcupacion,
              ISNULL(SUM(CASE WHEN R.ESTADO = 'CONFIRMADA' THEN R.CANTIDAD ELSE 0 END), 0) * E.PRECIO_ENTRADA AS TotalIngresos,
              E.ESTADO AS EstadoEvento
     FROM     EVENTO AS E
              LEFT OUTER JOIN
              RESERVA AS R
              ON E.EVENTO_ID = R.EVENTO_ID
     GROUP BY E.EVENTO_ID, E.TITULO, E.CAPACIDAD_MAXIMA, E.PRECIO_ENTRADA, E.ESTADO)





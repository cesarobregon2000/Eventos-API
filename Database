CREATE OR ALTER PROCEDURE [dbo].[PR_CONFIRMAR_PAGO]
@RESERVA_ID INT
AS
BEGIN
    DECLARE @ESTADO AS VARCHAR (20);
    BEGIN TRANSACTION;
    SELECT @ESTADO = ESTADO
    FROM   RESERVA WITH (UPDLOCK)
    WHERE  RESERVA_ID = @RESERVA_ID;
    IF @ESTADO = 'CONFIRMADA'
        BEGIN
            ROLLBACK;
            RAISERROR ('La reserva ya esta confirmada', 16, 1);
            RETURN;
        END
    IF @ESTADO = 'CANCELADA'
        BEGIN
            ROLLBACK;
            RAISERROR ('No se puede confirmar una reserva cancelada', 16, 1);
            RETURN;
        END
    UPDATE RESERVA
    SET    ESTADO             = 'CONFIRMADA',
           FECHA_CONFIRMACION = GETDATE(),
           CODIGO_RESERVA     = CONCAT('EV-', RIGHT('000000' + CAST (@RESERVA_ID AS VARCHAR), 6))
    WHERE  RESERVA_ID = @RESERVA_ID;
    COMMIT TRANSACTION;
END


